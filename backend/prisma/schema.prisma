// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String?
  name      String?
  image     String?
  role      Role    @default(MEMBER)
  provider  String  @default("credentials")
  createdAt   DateTime  @default(now())
  transaction   Transaction[]
  categories  Category[]
  budgets     Budget[]
  auditLogs   AuditLog[]
  splitBillItems    SplitBillItem[]
  ownedWorkspaces   Workspace[]   @relation("WorkspaceOwner")
  WorkspaceMember   WorkspaceMember[]
}

model Category {
  id        String  @id @default(cuid())
  name      String
  icon      String
  color     String
  userId    String
  user      User @relation(fields:[userId], references:[id])
  transactions Transaction[]
  budget    Budget?
}

model ExchangeRate {
  id        String  @id @default(cuid())
  date      String  // format: "2025-01-15"
  usdToIdr  Float
  fetchedAt DateTime @default(now())
}

model Transaction {
  id        String  @id @default(cuid())
  userId    String
  categoryId  String
  amount    Float
  currency  String
  amountInIDR Float
  exchangeRate  Float
  type        Type    // INCOME | EXPENSE
  description String?
  date        DateTime
  receiptImage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category  @relation(fields: [categoryId], references: [id])
  splitBill     SplitBill?
}

model SplitBill {
  id              String  @id @default(cuid())
  transactionId   String  @unique
  totalAmount     Float
  note            String?
  createdAt       DateTime  @default(now())
  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  items           SplitBillItem[]
}

model SplitBillItem {
  id      String  @id @default(cuid())
  splitBillId String
  userId    String?
  name      String
  email     String?
  amount    Float
  isPaid    Boolean @default(false)
  paidAt    DateTime?
  splitBill SplitBill @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])
}

model Budget {
  id        String  @id @default(cuid())
  userId    String
  categoryId  String  @unique
  limitIDR    Float
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Workspace {
  id        String    @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime  @default(now())
  owner     User      @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members   WorkspaceMember[] 
}

model WorkspaceMember {
  id          String  @id @default(cuid())
  workspaceId String
  userId      String
  permission  Permission @default(VIEW)
  inviteStatus  InviteStatus @default(PENDING)
  joinedAt    DateTime    @default(now())
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id      String  @id @default(cuid())
  userId  String
  action  String
  entity  String
  entityId  String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime  @default(now())
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum Role {
  ADMIN
  MEMBER
}

enum Type {
  INCOME
  EXPENSE
}

enum Permission {
  VIEW
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}
